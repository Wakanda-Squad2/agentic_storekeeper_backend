# Copy to `.env` for local dev or Docker Compose (`docker compose up --build` from this directory).
#
# --- SECRET_KEY (required for production; JWT signing) ---
# Add a line:  SECRET_KEY=<paste>
# Generate:
#   python scripts/generate_secret_key.py
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# If you omit SECRET_KEY, the app uses a dev-only default (not for production).

# Database (PostgreSQL for production)
DATABASE_URL=postgresql://storekeeper:storekeeper_pass@localhost:5432/storekeeper_db

# PostgreSQL Docker settings (used by docker-compose healthcheck — keep all three aligned)
POSTGRES_USER=storekeeper
POSTGRES_PASSWORD=storekeeper_pass
POSTGRES_DB=storekeeper_db

# Redis — local uvicorn: use localhost. Docker Compose overrides REDIS_URL to redis://redis:6379/0 for the API container.
REDIS_URL=redis://127.0.0.1:6379/0

# CORS (JSON array of origins)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# AI/ML - OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key-here
AI_MODEL=google/gemini-2.5-flash-preview
